<mujoco model="biped">
  <!-- Physics settings  set to -9.81 bc Earths actual gravitational acceleration
  its - because gravity pulls downward in the negative z direction-->
  <option timestep="0.002" gravity="0 0 -9.81"/>

  <visual>
    <headlight ambient="0.4 0.4 0.4"/>
  </visual>

  <!-- defines materials/textures -->
  <asset>
    <texture type="skybox" builtin="gradient"
             rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="512"/>
    <texture name="ground" type="2d" builtin="checker"
             rgb1="0.8 0.8 0.8" rgb2="0.6 0.6 0.6"
             width="512" height="512"/>
    <material name="ground" texture="ground" texrepeat="10 10"/>
    <material name="body" rgba="0.5 0.5 0.5 1"/>
    <material name="leg" rgba="0.2 0.4 0.9 1"/>
    <material name="foot" rgba="0.1 0.2 0.6 1"/>
  </asset>

  <!-- The world -->
  <worldbody>

    <!-- Ground plane -->
    <geom name="floor" type="plane" size="50 50 0.1"
          material="ground" condim="3" friction="1.0 0.005 0.0001"/>

    <!-- lighting -->
    <light name="sun" pos="0 0 10" dir="0 0 -1"
           diffuse="0.8 0.8 0.8" specular="0.2 0.2 0.2"/>

    <!-- ===== LOUIS BODY xyz ===== -->
    <body name="torso" pos="0 0 0.85">

      <freejoint name="root"/>

      <!-- Torso shape -->
      <geom name="torso" type="capsule" size="0.10 0.15"
            material="body" density="1000"/>

      <!-- shoulder left -->
      <geom name="left_shoulder_ball" type="sphere" size="0.05"
            pos="0 0.15 0.05" material="body"/>

      <!-- shoulder right -->
      <geom name="right_shoulder_ball" type="sphere" size="0.05"
          pos="0 -0.15 0.05" material="body"/>
      <!-- ===== LEFT LEG ===== -->
      <body name="left_thigh" pos="0 0.08 -0.15">
        <joint name="left_hip" type="hinge"
               axis="0 1 0" range="-120 40"
               damping="2" stiffness="0"/>
        <geom name="left_thigh" type="capsule"
              size="0.05 0.2" fromto="0 0 0 0 0 -0.4"
              material="leg"/>

        <body name="left_shin" pos="0 0 -0.4">
          <joint name="left_knee" type="hinge"
                 axis="0 1 0" range="-120 0"
                 damping="2" stiffness="0"/>
          <geom name="left_shin" type="capsule"
                size="0.04 0.2" fromto="0 0 0 0 0 -0.4"
                material="leg"/>

          <body name="left_foot" pos="0 0 -0.4">
            <joint name="left_ankle" type="hinge"
                   axis="0 1 0" range="-45 45"
                   damping="1" stiffness="0"/>
            <geom name="left_foot" type="box"
                  size="0.09 0.04 0.015" pos="0.02 0 -0.02"
                  material="foot" friction="1.5 0.005 0.0001"/>
          </body>

        </body>
      </body>

      <!-- ===== RIGHT LEG ===== -->
      <body name="right_thigh" pos="0 -0.08 -0.15">
        <joint name="right_hip" type="hinge"
               axis="0 1 0" range="-120 40"
               damping="2" stiffness="0"/>
        <geom name="right_thigh" type="capsule"
              size="0.05 0.2" fromto="0 0 0 0 0 -0.4"
              material="leg"/>

        <body name="right_shin" pos="0 0 -0.4">
          <joint name="right_knee" type="hinge"
                 axis="0 1 0" range="-120 0"
                 damping="2" stiffness="0"/>
          <geom name="right_shin" type="capsule"
                size="0.04 0.2" fromto="0 0 0 0 0 -0.4"
                material="leg"/>

          <body name="right_foot" pos="0 0 -0.4">
            <joint name="right_ankle" type="hinge"
                   axis="0 1 0" range="-45 45"
                   damping="1" stiffness="0"/>
            <geom name="right_foot" type="box"
                  size="0.09 0.04 0.015" pos="0.02 0 -0.02"
                  material="foot" friction="1.5 0.005 0.0001"/>
          </body>

        </body>
      </body>

        <!-- ===== LEFT ARM ===== -->
<body name="left_upper_arm" pos="0.0 0.15 0.05">
    <joint name="left_shoulder" type="hinge"
           axis="1 0 0" range="-90 90"
           damping="2" stiffness="0"/>
    <geom name="left_upper_arm" type="capsule"
          size="0.03 0.1" fromto="0 0 0 0 0 -0.3"
          material="leg"/>

    <body name="left_forearm" pos="0 0 -0.3">
        <joint name="left_elbow" type="hinge"
               axis="1 0 0" range="-120 0"
               damping="1" stiffness="0"/>
        <geom name="left_forearm" type="capsule"
              size="0.025 0.1" fromto="0 0 0 0 0 -0.25"
              material="leg"/>
    </body>
</body>

<!-- ===== RIGHT ARM ===== -->
<body name="right_upper_arm" pos="0.0 -0.15 0.05">
    <joint name="right_shoulder" type="hinge"
           axis="1 0 0" range="-90 90"
           damping="2" stiffness="0"/>
    <geom name="right_upper_arm" type="capsule"
          size="0.03 0.1" fromto="0 0 0 0 0 -0.3"
          material="leg"/>

    <body name="right_forearm" pos="0 0 -0.3">
        <joint name="right_elbow" type="hinge"
               axis="1 0 0" range="-120 0"
               damping="1" stiffness="0"/>
        <geom name="right_forearm" type="capsule"
              size="0.025 0.1" fromto="0 0 0 0 0 -0.25"
              material="leg"/>
    </body>
</body>

    </body>
  </worldbody>

  <!-- ===== (actuators) ===== -->
<actuator>
    <motor name="left_hip"    joint="left_hip"    gear="150" ctrlrange="-1 1"/>
    <motor name="left_knee"   joint="left_knee"   gear="150" ctrlrange="-1 1"/>
    <motor name="left_ankle"  joint="left_ankle"  gear="100" ctrlrange="-1 1"/>
    <motor name="right_hip"   joint="right_hip"   gear="150" ctrlrange="-1 1"/>
    <motor name="right_knee"  joint="right_knee"  gear="150" ctrlrange="-1 1"/>
    <motor name="right_ankle" joint="right_ankle" gear="100" ctrlrange="-1 1"/>
    <motor name="left_shoulder"  joint="left_shoulder"  gear="50" ctrlrange="-1 1"/>
    <motor name="left_elbow"     joint="left_elbow"     gear="50" ctrlrange="-1 1"/>
    <motor name="right_shoulder" joint="right_shoulder" gear="50" ctrlrange="-1 1"/>
    <motor name="right_elbow"    joint="right_elbow"    gear="50" ctrlrange="-1 1"/>
</actuator>

</mujoco>